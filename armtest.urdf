<?xml version="1.0"?>
<robot name="better_arm">

  <!-- ===== BASE PLATE ===== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025"/>
      <geometry><box size="0.18 0.18 0.05"/></geometry>
      <material name="dark_metal"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025"/>
      <geometry><box size="0.18 0.18 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.025"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ===== SHOULDER HUB (sphere) ===== -->
  <link name="shoulder_hub">
    <visual>
      <geometry><sphere radius="0.055"/></geometry>
      <material name="orange"><color rgba="1.0 0.45 0.0 1"/></material>
    </visual>
    <collision><geometry><sphere radius="0.055"/></geometry></collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="base_to_shoulder" type="fixed">
    <parent link="base_link"/>
    <child link="shoulder_hub"/>
    <origin xyz="0 0 0.08"/>
  </joint>

  <!-- ===== UPPER ARM ===== -->
  <link name="upper_arm">
    <visual>
      <!-- main tube -->
      <origin xyz="0 0 0.18"/>
      <geometry><cylinder radius="0.035" length="0.36"/></geometry>
      <material name="silver"><color rgba="0.75 0.75 0.8 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.18"/>
      <geometry><cylinder radius="0.035" length="0.36"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.18"/>
      <mass value="0.6"/>
      <inertia ixx="0.007" iyy="0.007" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="shoulder_rotate" type="revolute">
    <parent link="shoulder_hub"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 0.055"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="150" velocity="1.5"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ===== ELBOW HUB ===== -->
  <link name="elbow_hub">
    <visual>
      <geometry><sphere radius="0.042"/></geometry>
      <material name="orange"><color rgba="1.0 0.45 0.0 1"/></material>
    </visual>
    <collision><geometry><sphere radius="0.042"/></geometry></collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="upper_to_elbow" type="fixed">
    <parent link="upper_arm"/>
    <child link="elbow_hub"/>
    <origin xyz="0 0 0.36"/>
  </joint>

  <!-- ===== FOREARM ===== -->
  <link name="forearm">
    <visual>
      <origin xyz="0 0 0.14"/>
      <geometry><cylinder radius="0.027" length="0.28"/></geometry>
      <material name="silver"><color rgba="0.75 0.75 0.8 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.14"/>
      <geometry><cylinder radius="0.027" length="0.28"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.14"/>
      <mass value="0.4"/>
      <inertia ixx="0.004" iyy="0.004" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="elbow_bend" type="revolute">
    <parent link="elbow_hub"/>
    <child link="forearm"/>
    <origin xyz="0 0 0.042"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="0.1" effort="100" velocity="1.5"/>
    <dynamics damping="0.4" friction="0.1"/>
  </joint>

  <!-- ===== WRIST HUB ===== -->
  <link name="wrist_hub">
    <visual>
      <geometry><sphere radius="0.032"/></geometry>
      <material name="orange"><color rgba="1.0 0.45 0.0 1"/></material>
    </visual>
    <collision><geometry><sphere radius="0.032"/></geometry></collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="forearm_to_wrist" type="fixed">
    <parent link="forearm"/>
